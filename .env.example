# Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string (MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/gcams?retryWrites=true&w=majority

# JWT Secret (generate a strong random string — at least 64 chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_64chars_min

# JWT expiry duration
JWT_EXPIRES_IN=8h

# Server port
PORT=5000

# Frontend URL for CORS (comma-separated if multiple)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Node environment
NODE_ENV=development
